meta {
  name: Update Auditor Regis Status
  type: http
  seq: 2
}

put {
  url: {{DEMP_BASE_URL}}/api/climate-finance/auditor/access-request/status/update/{{id}}
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  answer: accept
