meta {
  name: BigData
}

auth {
  mode: none
}

vars:pre-request {
  BIGDATA_BASE_URL_DEV: https://big-data-api-dev.vekin.co.th
  LOCALHOST: http://localhost:3002
  BIGDATA_BASE_URL_PROD: https://big-data-api.vekin.co.th
}

docs {
  All API in this collection required cookies in the headers, for postman testing, we autoset the cookies after login
}
